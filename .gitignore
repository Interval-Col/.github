# macOS
.DS_Store
.AppleDouble
.LSOverride

# macOS custom-folder icon resource file (literally "Icon" + a CR → 5 chars).
# Use Icon? (not bare "Icon") so it does NOT swallow legit icon/ dirs or Icon.vue
# on a case-insensitive filesystem.
Icon?

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share, NFS, SMB, or WebDAV
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
